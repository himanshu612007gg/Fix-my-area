rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPostOwner() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function isSubmissionOwner() {
      return signedIn() && resource.data.post.userId == request.auth.uid;
    }

    function isTokenOwner() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    // The app now uses Firebase Auth for citizens, authorities, and admin.
    // Admin approval state is stored in Firestore user documents and enforced in the UI.
    // These rules keep the project authenticated-only without relying on legacy PIN flows.

    match /users/{userId} {
      allow read, create, update: if signedIn();
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin() || isPostOwner();
    }

    match /governmentSubmissions/{submissionId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin() || isSubmissionOwner();
    }

    match /userStats/{userId} {
      allow read, create, update: if signedIn();
      allow delete: if false;
    }

    match /tokens/{tokenId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin() || isTokenOwner();
    }

    match /rewardRedemptions/{redemptionId} {
      allow read, create, update: if signedIn();
      allow delete: if false;
    }
  }
}
